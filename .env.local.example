# ── Admin auth ────────────────────────────────────────────────────────────────
# Password for /admin/requests login page
ADMIN_PASSWORD=change_me_before_deploy

# ── Email notifications ────────────────────────────────────────────────────────
# Recipient for new-request alerts
ADMIN_EMAIL=admin@yourdomain.com

# SMTP server settings
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Sender address shown in the email From field
SMTP_FROM=noreply@yourdomain.com

# ── Site URL ───────────────────────────────────────────────────────────────────
# Full base URL of this deployment — used for admin link and image links in emails
# No trailing slash
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
