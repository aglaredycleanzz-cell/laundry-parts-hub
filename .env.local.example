# ── Admin auth ────────────────────────────────────────────────────────────────
# Password for /admin/requests login page
ADMIN_PASSWORD=change_me_before_deploy

# ── Email notifications ────────────────────────────────────────────────────────
# Recipient for new-request alerts
ADMIN_EMAIL=admin@yourdomain.com

# SMTP server settings
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Sender address shown in the email From field
SMTP_FROM=noreply@yourdomain.com

# ── Site URL ───────────────────────────────────────────────────────────────────
# Full base URL of this deployment — used for admin link and image links in emails
# No trailing slash
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
# MySQL connection string used by Drizzle ORM at runtime
DATABASE_URL=mysql://user:password@host:3306/laundry_parts_hub

# ── Auth / Session ─────────────────────────────────────────────────────────────
# Cookie-signing secret (use a long random string in production)
JWT_SECRET=replace_with_a_long_random_string

# OAuth provider used by the auth flow
OAUTH_SERVER_URL=https://auth.example.com
VITE_APP_ID=your_app_id

# Open ID of the platform owner — that user is auto-promoted to "admin" on login
OWNER_OPEN_ID=

# ── LLM Gateway (Vision + Support agents) ──────────────────────────────────────
# Used by server/_core/llm.ts to talk to Claude/Gemini for image recognition
# and the upcoming AI agents. Leave BUILT_IN_FORGE_API_URL empty to use the
# managed default.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
